module fixtures.full_type_check.session_w_implicit_fallible_call_fail

type SourceError {
  code: Text
}

task source() -> Result UInt, SourceError {
  why:
    expose a known fallible source
  fails when:
    the source fails
  does:
    fail SourceError.origin
}

task caller() -> Result UInt, SourceError {
  why:
    reject implicit failure propagation
  fails when:
    the source fails
  does:
    let value = source()
    return value
}
