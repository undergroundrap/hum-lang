app implicit_replay_call {
  uses:
    clock.replay

  starts with:
    run_tool

  task run_tool -> Result Unit, ReplayClockError {
    uses:
      clock.replay

    fails when:
      runner replay input is unavailable

    allocates:
      callee-defined allocation behavior

    does:
      let tick = clock_replay_tick()
      return ()
  }
}
