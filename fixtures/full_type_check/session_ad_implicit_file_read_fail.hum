app implicit_file_read {
  why:
    reject implicit propagation from the hardened file reader

  uses:
    files.read

  starts with:
    run_tool

  task run_tool(input: Path) -> Result Unit, FileReadError {
    uses:
      files.read

    fails when:
      the exact file operation fails

    allocates:
      one bounded file buffer

    does:
      let text = files_read_text(input)
      return
  }
}
