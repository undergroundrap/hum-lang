module fixtures.ownership_check.session_j_double_consume_fail

task take(consume value: Int) -> Int {
  why:
    provide a consume boundary for the misuse probe

  does:
    return value
}

task double_consume() -> Int {
  why:
    prove ownership rejects consuming the same local twice

  does:
    let value: Int = 7
    let first: Int = take(consume value)
    return take(consume value)
}