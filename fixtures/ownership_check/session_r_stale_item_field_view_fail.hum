module fixtures.ownership_check.session_r_stale_item_field_view_fail

type WorkItem {
  done: Bool
  pinned: Bool
}

task stale_item_done_view(change item: WorkItem) -> Bool {
  why:
    reject a stale work-item field view after completing the item

  does:
    let done_view = borrow item.done
    set item.done = true
    return done_view
}
