module fixtures.effect_check.session_w_missing_fails_when_fail

type SourceError {
  code: Text
}

task source() -> Result UInt, SourceError {
  why:
    expose a known fallible source
  fails when:
    the source fails
  does:
    fail SourceError.origin
}

task caller() -> Result UInt, SourceError {
  why:
    reject propagation without a meaningful failure declaration
  does:
    let value = try source()
    return value
}
